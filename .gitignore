# Byte-compiled
__pycache__/
*.py[cod]
*$py.class

# Virtual environment
venv/
.venv/
env/
*.egg-info/

# IDE
.vscode/
.idea/
*.swp
*.swo

# SQLite databases
*.db

# Uploaded images (keep test_samples/ manually if needed)
data/test_images/*.jpg
data/test_images/*.jpeg
data/test_images/*.png

# Large model files in root (use models/ instead)
/yolov8s.pt
/yolov8n.pt
/yolov8x.pt
/best.pt

# Large CSV datasets (script auto-generates sample data)
data/*.csv

# OS files
.DS_Store
Thumbs.db

# Output violation images (generated at runtime)
outputs/violations/*.jpg
models/yolov8n.pt
analytics/*.png
